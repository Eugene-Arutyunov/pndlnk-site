{% macro caseMeta(page) %}
  {% set slug = page.url | projectSlugFromUrl %}
  {% set p = projects | projectBySlug(slug) %}
  {% if p %}
  <div class="ids__space XL"></div>
  <div class="case-page__header">
    <a href="/projects/">← Все проекты</a>
    {% if p.logo and p.logo.kind == 'include' and p.logo.path %}
    <div class="case-page__brand-logo" aria-hidden="true">
      {% include p.logo.path %}
    </div>
    {% elif p.logo and p.logo.kind == 'asset' and p.logo.path %}
    <div class="case-page__brand-logo" aria-hidden="true">
      <img src="{{ p.logo.path }}" alt="" />
    </div>
    {% elif p.logoInclude %}
    <div class="case-page__brand-logo" aria-hidden="true">
      {% include p.logoInclude %}
    </div>
    {% elif p.logoAsset %}
    <div class="case-page__brand-logo" aria-hidden="true">
      <img src="{{ p.logoAsset }}" alt="" />
    </div>
    {% endif %}

    {% if p.type.length or p.industryTags.length or p.product or p.year %}
    <ul class="case-page__tags" aria-label="Теги кейса">
      {% for tag in p.type %}
      <li><span class="case-page__tag">{{ tag }}</span></li>
      {% endfor %}
      {% for tag in p.industryTags %}
      <li><span class="case-page__tag case-page__tag--industry">{{ tag }}</span></li>
      {% endfor %}
      {% if p.product %}
      <li><span class="case-page__tag case-page__tag--product">{{ p.product }}</span></li>
      {% endif %}
      {% if p.year %}
      <li><span class="case-page__tag case-page__tag--year">{{ p.year }}</span></li>
      {% endif %}
    </ul>
    {% endif %}
  </div>
  <div class="ids__space XS"></div>
  <h1>{{ p.title }}</h1>
  <div class="ids__space M"></div>
  {% endif %}
{% endmacro %}
